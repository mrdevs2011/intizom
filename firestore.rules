rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────────────
    //  Yordamchi funksiyalar
    // ──────────────────────────────────────────────────────────

    // Sana formati: "2026-06-23"  →  YYYY-MM-DD
    function isValidDateId(dayId) {
      return dayId.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    // Loyiha muddati: 23 iyun – 1 sentabr 2026
    function isInRange(dayId) {
      return dayId >= '2026-06-23' && dayId <= '2026-09-01';
    }

    // Faqat ruxsat etilgan kalitlar (journal ixtiyoriy)
    function hasOnlyAllowedKeys(data) {
      return data.keys().hasOnly([
        'n_bomdod', 'n_peshin', 'n_asr', 'n_shom', 'n_xufton',
        't_js', 't_vim', 't_din',
        'journal'
      ]);
    }

    // Namoz maydonlari — bool yoki mavjud emas
    function namozFieldsValid(data) {
      return
        (!('n_bomdod' in data) || data.n_bomdod is bool) &&
        (!('n_peshin' in data) || data.n_peshin is bool) &&
        (!('n_asr'    in data) || data.n_asr    is bool) &&
        (!('n_shom'   in data) || data.n_shom   is bool) &&
        (!('n_xufton' in data) || data.n_xufton is bool);
    }

    // Vazifa maydonlari — bool yoki mavjud emas
    function taskFieldsValid(data) {
      return
        (!('t_js'  in data) || data.t_js  is bool) &&
        (!('t_vim' in data) || data.t_vim is bool) &&
        (!('t_din' in data) || data.t_din is bool);
    }

    // Journal: string, max 1000 belgi
    function journalValid(data) {
      return !('journal' in data) || (
        data.journal is string &&
        data.journal.size() <= 1000
      );
    }

    // Birlashtirilgan yozish validatsiyasi
    function isValidDayDoc(data) {
      return
        hasOnlyAllowedKeys(data) &&
        namozFieldsValid(data)   &&
        taskFieldsValid(data)    &&
        journalValid(data);
    }

    // ──────────────────────────────────────────────────────────
    //  Asosiy qoidalar
    // ──────────────────────────────────────────────────────────

    // Faqat /users/user_main/days/{dayId} yo'li ruxsat etiladi.
    // Boshqa barcha yo'llar — yopiq.
    match /users/user_main/days/{dayId} {

      // O'qish — hamma (sync ishlashi uchun; hech qanday maxfiy ma'lumot yo'q)
      allow read: if true;

      // Yozish — faqat to'g'ri sana formatida, loyiha muddatida va
      // validatsiyadan o'tgan ma'lumot bilan
      allow write: if
        isValidDateId(dayId) &&
        isInRange(dayId)     &&
        isValidDayDoc(request.resource.data);
    }

    // /users/user_main o'zi (meta-hujjat) — faqat o'qish
    match /users/user_main {
      allow read:  if true;
      allow write: if false;
    }

    // Qolgan barcha yo'llar — to'liq yopiq
    match /{document=**} {
      allow read:  if false;
      allow write: if false;
    }
  }
}
